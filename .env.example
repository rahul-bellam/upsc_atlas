# Copy this file to .env.local. Never commit .env.local or real credentials.

# AI place dossiers: "openai" (default) or "deepseek"
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Required for place-specific news from the previous six months.
# Your NewsAPI plan must permit historical /v2/everything requests for this window.
NEWS_KEY=your_news_api_key_here

# Identify the app to the public Nominatim geocoding service. Include a contact URL or email.
NOMINATIM_USER_AGENT="UPSC-Atlas-Explorer/1.0 (contact: you@example.com)"

# Optional but recommended in production: shared rate limiting across serverless instances.
# If omitted, the app uses a bounded per-process development fallback.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
